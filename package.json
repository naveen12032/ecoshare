{
  "name": "ecocircle",
  "version": "1.0.0",
  "description": "EcoCircle - local eco community resource sharing platform",
  "main": "index.html",
  "scripts": {
    "env:generate": "node scripts/generate-env-config.js",
    "dev": "npm run env:generate && npx http-server -p 3000 -c-1",
    "build": "npm run env:generate && node scripts/build.js",
    "test": "jest --verbose",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@google-cloud/storage": "^7.21.0",
    "firebase": "^12.14.0",
    "node-localstorage": "^3.0.5"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1"
  }
}
